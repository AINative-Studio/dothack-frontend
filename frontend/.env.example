# DotHack Backend API Configuration
# Copy this file to .env.local and fill in your actual values

# Backend API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_VERSION=v1

# ZeroDB Configuration (for backend communication)
# Get these from your ZeroDB/AINative dashboard
ZERODB_EMAIL=your-email@example.com
ZERODB_PASSWORD=your-secure-password
ZERODB_API_KEY=your-zerodb-api-key
ZERODB_API_BASE_URL=https://api.ainative.studio

# Frontend Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Authentication Configuration
NEXT_PUBLIC_AINATIVE_AUTH_URL=https://api.ainative.studio/v1/auth

# WebSocket Configuration (optional, for real-time features)
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Production overrides (set these in deployment environment)
# NEXT_PUBLIC_API_URL=https://api.dothack.com/api/v1
# NEXT_PUBLIC_WS_URL=wss://ws.dothack.com
# ZERODB_API_BASE_URL=https://api.ainative.studio
